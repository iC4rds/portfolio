{
	"name": "portfolio",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "bun run --bun vite dev",
		"build": "bun run --bun vite build",
		"preview": "bun run --bun vite preview",
		"vercel-build": "bun run build",
		"prepare": "bun run --bun svelte-kit sync || echo ''",
		"check": "bun run --bun svelte-kit sync && bun run --bun svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "bun run --bun svelte-kit sync && bun run --bun svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "bun run --bun prettier --write .",
		"lint": "bun run --bun prettier --check . && bun run --bun eslint .",
		"db:push": "bun run --bun drizzle-kit push",
		"db:migrate": "bun run --bun drizzle-kit migrate",
		"db:studio": "bun run --bun drizzle-kit studio"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.2",
		"@sveltejs/adapter-netlify": "^6.0.2",
		"@sveltejs/adapter-vercel": "^6.3.2",
		"@sveltejs/kit": "^2.52.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.0",
		"@types/node": "^22.19.11",
		"drizzle-kit": "^0.30.6",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^16.5.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.0",
		"svelte": "^5.53.0",
		"svelte-check": "^4.4.1",
		"tailwindcss": "^4.2.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.0",
		"vite": "^7.3.1",
		"wrangler": "^4.67.0"
	},
	"dependencies": {
		"@libsql/client": "0.14.0",
		"drizzle-orm": "^0.40.1"
	}
}
